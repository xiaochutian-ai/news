<div class="panel">
  <div class="section-head">
    <div class="section-title">
      <div class="section-kicker">Run Snapshot</div>
      <h2>结果摘要</h2>
    </div>
    <div class="hint">用均衡的四块信息卡展示本次运行结果，避免单块过挤或过空。</div>
  </div>
  {% if result %}
  {% set raw_count = result.raw_count | int %}
  {% set filtered_count = result.filtered_count | int %}
  {% set selected_count = result.selected_count | int %}
  <div class="summary-grid summary-grid-balanced">
    <section class="summary-card summary-card-metrics">
      <div class="summary-card-title">核心统计</div>
      <div class="stats stats-balanced">
        <div class="stat">
          <div class="label">原始候选数</div>
          <div class="value">{{ raw_count }}</div>
          <div class="foot">全部抓取到的候选稿件</div>
        </div>
        <div class="stat">
          <div class="label">过滤后数量</div>
          <div class="value">{{ filtered_count }}</div>
          <div class="foot">通过民生主题判断后的剩余条目</div>
        </div>
        <div class="stat">
          <div class="label">最终入选数</div>
          <div class="value">{{ selected_count }}</div>
          <div class="foot">进入晨报草稿的最终条目</div>
        </div>
      </div>
    </section>
    <section class="summary-card summary-card-conversion">
      <div class="summary-card-title">阶段转化</div>
      <div class="summary-conversion-list">
        <div class="summary-conversion-item">
          <div class="summary-meta-label">原始 -> 过滤后</div>
          <div class="summary-conversion-value">{{ raw_count }} -> {{ filtered_count }}</div>
        </div>
        <div class="summary-conversion-item">
          <div class="summary-meta-label">过滤后 -> 最终入选</div>
          <div class="summary-conversion-value">{{ filtered_count }} -> {{ selected_count }}</div>
        </div>
      </div>
    </section>
    <section class="summary-card summary-card-config">
      <div class="summary-card-title">运行配置</div>
      <div class="summary-meta-grid">
        <div class="summary-meta-item">
          <div class="summary-meta-label">时间窗口</div>
          <div class="summary-meta-value">稿件日期：{{ result.digest_date }}</div>
          <div class="summary-meta-value">来源日期：{{ result.source_date }}</div>
        </div>
        <div class="summary-meta-item">
          <div class="summary-meta-label">本次数据源</div>
          <div class="summary-source-badges">
            {% for source in result.selected_sources %}
            <span class="summary-source-badge">{{ source }}</span>
            {% endfor %}
          </div>
        </div>
        <div class="summary-meta-item">
          <div class="summary-meta-label">运行策略</div>
          <div class="summary-meta-value">过滤策略：{{ result.filter_strategy | default("standard") }}</div>
          <div class="summary-meta-value">时间策略：{{ result.time_strategies | default(["source_day"]) | join(" / ") if result.time_strategies else "none" }}</div>
          <div class="summary-meta-value">去重策略：{{ result.dedupe_strategy | default("standard") }}</div>
        </div>
      </div>
    </section>
    <section class="summary-card summary-card-artifacts">
      <div class="summary-card-title">产物入口</div>
      <div class="summary-link-row">
        <a href="{{ result.html_url }}" target="_blank" rel="noopener noreferrer">HTML</a>
        <a href="{{ result.json_url }}" target="_blank" rel="noopener noreferrer">JSON</a>
      </div>
    </section>
  </div>
  {% else %}
  <div class="empty">还没有执行记录，先在上方完成控制项选择并执行晨报生成。</div>
  {% endif %}
</div>
