<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <title>民生晨报 Dashboard</title>
  <style>
    :root {
      --bg: #f3f6fb;
      --panel: #ffffff;
      --panel-soft: #f7f9fc;
      --border: #d9e1ef;
      --border-strong: #b6c6e0;
      --text: #152033;
      --muted: #5a667c;
      --accent: #2563eb;
      --accent-soft: #e8f0ff;
      --accent-strong: #0f4bd8;
      --danger-soft: #fff1f3;
      --danger-border: #f3c7d0;
      --shadow: 0 14px 40px rgba(15, 23, 42, 0.08);
    }
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      margin: 0;
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.08), transparent 22%),
        linear-gradient(180deg, #f7f9fd 0%, #eef3f9 100%);
    }
    .page { max-width: 1240px; margin: 0 auto; padding: 28px 20px 44px; }
    .panel {
      background: var(--panel);
      border-radius: 18px;
      padding: 22px;
      box-shadow: var(--shadow);
      border: 1px solid rgba(217, 225, 239, 0.88);
      margin-bottom: 18px;
    }
    h1 { margin: 0 0 8px; font-size: 30px; letter-spacing: -0.02em; }
    h2 { margin: 0; font-size: 22px; letter-spacing: -0.02em; }
    h3 { margin: 0; font-size: 16px; letter-spacing: -0.01em; }
    p { margin: 0; color: var(--muted); line-height: 1.6; }
    label { font-size: 14px; color: var(--text); }
    button {
      background: linear-gradient(135deg, var(--accent), var(--accent-strong));
      color: #fff;
      border: 0;
      border-radius: 12px;
      padding: 12px 18px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      box-shadow: 0 10px 24px rgba(37, 99, 235, 0.2);
    }
    select {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px 12px;
      background: #fff;
      color: var(--text);
      font-size: 14px;
    }
    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 18px;
    }
    .section-title {
      display: grid;
      gap: 8px;
    }
    .section-kicker {
      color: var(--accent);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .hint {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.5;
    }
    .control-layout {
      display: grid;
      grid-template-columns: 1.2fr 1fr 0.9fr;
      gap: 14px;
      margin-top: 18px;
    }
    .control-group {
      background: var(--panel-soft);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 16px;
      display: grid;
      gap: 12px;
      align-content: start;
    }
    .control-group-title {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .control-group-copy {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.5;
    }
    .source-options,
    .time-options,
    .control-stack,
    .summary-meta-grid,
    .article-stack {
      display: grid;
      gap: 10px;
    }
    .source-option,
    .time-option {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      padding: 11px 12px;
      border-radius: 12px;
      background: #fff;
      border: 1px solid var(--border);
    }
    .source-option input,
    .time-option input {
      margin-top: 2px;
      accent-color: var(--accent);
    }
    .source-option-text,
    .time-option-text {
      display: grid;
      gap: 4px;
    }
    .source-option-title,
    .time-option-title {
      font-weight: 600;
      color: var(--text);
    }
    .source-option-note,
    .time-option-note,
    .field-note {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.45;
    }
    .field-block {
      display: grid;
      gap: 8px;
    }
    .field-label {
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
    }
    .action-note {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
    }
    .error {
      color: #a61b35;
      margin-top: 14px;
      padding: 12px 14px;
      background: var(--danger-soft);
      border: 1px solid var(--danger-border);
      border-radius: 12px;
      font-size: 13px;
    }
    .summary-grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 14px;
      margin-top: 18px;
    }
    .summary-grid-balanced {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: stretch;
    }
    .summary-card {
      background: var(--panel-soft);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 16px;
      display: grid;
      gap: 14px;
      align-content: start;
      min-height: 100%;
    }
    .summary-card-title {
      color: var(--text);
      font-size: 15px;
      font-weight: 700;
    }
    .stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }
    .stats-balanced {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .stat {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 16px;
    }
    .stat .label {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .stat .value {
      font-size: 30px;
      font-weight: 700;
      margin-top: 10px;
      color: var(--text);
    }
    .stat .foot {
      margin-top: 8px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.4;
    }
    .summary-meta-item {
      display: grid;
      gap: 5px;
    }
    .summary-meta-label {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .summary-meta-value {
      font-size: 14px;
      color: var(--text);
      line-height: 1.5;
    }
    .summary-link-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .summary-source-badges {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .summary-source-badge {
      background: var(--accent-soft);
      color: var(--accent-strong);
      border-radius: 999px;
      font-size: 12px;
      font-weight: 600;
      padding: 5px 9px;
    }
    .summary-conversion-list {
      display: grid;
      gap: 12px;
    }
    .summary-conversion-item {
      padding: 12px;
      border-radius: 14px;
      background: #fff;
      border: 1px solid var(--border);
      display: grid;
      gap: 6px;
    }
    .summary-conversion-value {
      font-size: 24px;
      font-weight: 700;
      color: var(--text);
    }
    .summary-link-row a {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 9px 12px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent-strong);
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
    }
    .empty {
      color: #7b879a;
      font-size: 14px;
      line-height: 1.6;
      padding: 18px;
      border-radius: 14px;
      border: 1px dashed var(--border-strong);
      background: var(--panel-soft);
    }
    .stage-compare-shell {
      display: grid;
      gap: 18px;
      margin-top: 18px;
    }
    .stage-selector-panel,
    .stage-diff-card,
    .stage-summary-panel,
    .stage-primary-workspace,
    .stage-secondary-panel,
    .stage-compare-track {
      background: var(--panel-soft);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px;
    }
    .stage-selector-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
      margin-bottom: 12px;
    }
    .stage-status-rail {
      display: grid;
      gap: 8px;
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
    .stage-status-button {
      width: 100%;
      text-align: left;
      display: grid;
      gap: 6px;
      padding: 12px 12px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.72);
      color: var(--text);
      box-shadow: none;
      transition: border-color 0.18s ease, background 0.18s ease, transform 0.18s ease;
    }
    .stage-status-button {
      cursor: pointer;
    }
    .stage-status-button:hover {
      transform: translateY(-1px);
      border-color: rgba(37, 99, 235, 0.24);
    }
    .stage-status-button.is-active {
      background: linear-gradient(180deg, rgba(219, 234, 254, 0.9), rgba(239, 246, 255, 0.96));
      border-color: rgba(37, 99, 235, 0.42);
      box-shadow: inset 0 0 0 1px rgba(37, 99, 235, 0.08);
    }
    .stage-status-name {
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
    }
    .stage-status-meta {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.45;
    }
    .stage-compare-track { display: block; }
    .stage-compare-view {
      display: grid;
      gap: 14px;
    }
    .stage-workspace-head {
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 12px;
      margin-bottom: 12px;
    }
    .stage-workspace-copy {
      max-width: 460px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
      text-align: right;
    }
    .stage-summary-title {
      margin-top: 8px;
      color: var(--text);
      font-size: 22px;
      font-weight: 700;
    }
    .stage-summary-strip {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
    }
    .stage-summary-chip {
      min-height: 82px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.78);
      padding: 12px 14px;
      display: grid;
      gap: 8px;
      align-content: start;
    }
    .stage-summary-metric {
      color: var(--text);
      font-size: 20px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }
    .stage-summary-copy {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
    }
    .stage-overview-label {
      color: var(--muted);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .stage-compare-pair {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .stage-compare-pair.is-asymmetric {
      grid-template-columns: minmax(0, 1.24fr) minmax(320px, 0.76fr);
      align-items: start;
    }
    .stage-compare-panel,
    .stage-diff-card {
      display: grid;
      gap: 12px;
    }
    .stage-compare-panel.is-before {
      background: rgba(255, 255, 255, 0.52);
      border: 1px solid rgba(148, 163, 184, 0.18);
      border-radius: 14px;
      padding: 12px;
    }
    .stage-compare-panel.is-after {
      background: linear-gradient(180deg, rgba(239, 246, 255, 0.92), rgba(219, 234, 254, 0.82));
      border: 1px solid rgba(59, 130, 246, 0.24);
      border-radius: 16px;
      padding: 14px;
      box-shadow: 0 10px 30px rgba(37, 99, 235, 0.08);
    }
    .stage-panel-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
    }
    .stage-compare-panel.is-after .stage-panel-head {
      border-bottom-color: rgba(59, 130, 246, 0.18);
    }
    .stage-panel-count {
      color: var(--muted);
      font-size: 12px;
      font-weight: 600;
    }
    .source-breakdown-row {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .source-breakdown-chip {
      padding: 6px 10px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.88);
      border: 1px solid var(--border);
      color: var(--text);
      font-size: 11px;
      font-weight: 600;
    }
    .source-breakdown-row.is-before-breakdown {
      padding: 8px 10px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.46);
      border: 1px dashed rgba(148, 163, 184, 0.24);
    }
    .source-breakdown-row.is-after-breakdown {
      padding: 8px 10px;
      border-radius: 12px;
      background: rgba(239, 246, 255, 0.96);
      border: 1px solid rgba(59, 130, 246, 0.16);
    }
    .article-stack.is-dense {
      display: grid;
      gap: 8px;
    }
    .article-stack.is-focus {
      display: grid;
      gap: 12px;
    }
    .stage-secondary-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .stage-secondary-details {
      border-radius: 14px;
      border: 1px solid var(--border);
      background: rgba(255, 255, 255, 0.7);
      padding: 0 14px 14px;
    }
    .stage-secondary-details summary {
      list-style: none;
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      padding: 14px 0 12px;
      color: var(--text);
      font-size: 13px;
      font-weight: 700;
    }
    .stage-secondary-details summary::-webkit-details-marker { display: none; }
    .rank-change-list {
      display: grid;
      gap: 10px;
    }
    .rank-change-item {
      background: rgba(255, 255, 255, 0.88);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 12px;
      display: grid;
      gap: 6px;
    }
    .rank-change-item.is-neutral {
      border-style: dashed;
    }
    .rank-change-title {
      color: var(--text);
      font-size: 13px;
      font-weight: 700;
      line-height: 1.45;
    }
    .rank-change-meta {
      color: var(--muted);
      font-size: 11px;
      line-height: 1.45;
    }
    .article-item {
      background: rgba(255, 255, 255, 0.9);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 11px 12px;
      display: grid;
      gap: 8px;
      font-size: 12px;
    }
    .article-item.is-before-item {
      padding: 9px 10px;
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.78);
      gap: 6px;
    }
    .article-item.is-after-item {
      padding: 13px 14px;
      border-radius: 16px;
      background: rgba(255, 255, 255, 0.96);
      border-color: rgba(59, 130, 246, 0.22);
      box-shadow: 0 8px 24px rgba(37, 99, 235, 0.08);
    }
    .article-item.is-removed {
      background: #fff7f8;
      border-style: dashed;
      border-color: #e0b8c1;
    }
    .article-item a {
      color: var(--text);
      text-decoration: none;
      font-weight: 700;
      font-size: 13px;
      line-height: 1.45;
    }
    .article-item.is-before-item a {
      font-size: 12px;
      line-height: 1.4;
    }
    .article-item.is-after-item a {
      font-size: 14px;
      line-height: 1.45;
    }
    .article-meta {
      color: var(--muted);
      font-size: 11px;
      line-height: 1.45;
    }
    .article-item.is-before-item .article-meta {
      font-size: 10px;
      line-height: 1.4;
    }
    .article-item.is-after-item .article-meta {
      font-size: 11px;
      line-height: 1.5;
    }
    .article-summary-toggle {
      border-top: 1px dashed var(--border);
      padding-top: 8px;
    }
    .article-item.is-before-item .article-summary-toggle {
      padding-top: 6px;
    }
    .article-item.is-before-item .article-summary-body {
      font-size: 11px;
      line-height: 1.45;
    }
    .article-summary-toggle summary {
      cursor: pointer;
      color: var(--accent);
      font-size: 12px;
      font-weight: 600;
      list-style: none;
    }
    .article-summary-toggle summary::-webkit-details-marker { display: none; }
    .article-summary-body {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.55;
      margin-top: 8px;
    }
    .tag-list {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .tag {
      background: var(--accent-soft);
      color: var(--accent-strong);
      border-radius: 999px;
      font-size: 11px;
      font-weight: 600;
      padding: 4px 8px;
    }
    @media (max-width: 1024px) {
      .control-layout,
      .summary-grid,
      .stage-compare-pair,
      .stage-status-rail,
      .stage-summary-strip,
      .stage-secondary-row {
        grid-template-columns: 1fr;
      }
      .stage-compare-pair.is-asymmetric {
        grid-template-columns: 1fr;
      }
      .stage-workspace-head {
        align-items: start;
        flex-direction: column;
      }
      .stage-workspace-copy {
        max-width: none;
        text-align: left;
      }
    }
    @media (max-width: 720px) {
      .stats { grid-template-columns: 1fr; }
      .panel { padding: 18px; }
    }
  </style>
</head>
<body>
  <div class="page">
    {% include "_dashboard_generation_options.html.j2" %}
    {% include "_dashboard_summary.html.j2" %}
    {% include "_dashboard_stage_details.html.j2" %}
  </div>
</body>
</html>
