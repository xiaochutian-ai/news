<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <title>民生晨报 Dashboard</title>
  <style>
    :root {
      --bg: #f3f6fb;
      --panel: #ffffff;
      --panel-soft: #f7f9fc;
      --border: #d9e1ef;
      --border-strong: #b6c6e0;
      --text: #152033;
      --muted: #5a667c;
      --accent: #2563eb;
      --accent-soft: #e8f0ff;
      --accent-strong: #0f4bd8;
      --danger-soft: #fff1f3;
      --danger-border: #f3c7d0;
      --shadow: 0 14px 40px rgba(15, 23, 42, 0.08);
    }
    * { box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text);
      margin: 0;
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.08), transparent 22%),
        linear-gradient(180deg, #f7f9fd 0%, #eef3f9 100%);
    }
    .page { max-width: 1240px; margin: 0 auto; padding: 28px 20px 44px; }
    .panel {
      background: var(--panel);
      border-radius: 18px;
      padding: 22px;
      box-shadow: var(--shadow);
      border: 1px solid rgba(217, 225, 239, 0.88);
      margin-bottom: 18px;
    }
    h1 { margin: 0 0 8px; font-size: 30px; letter-spacing: -0.02em; }
    h2 { margin: 0; font-size: 22px; letter-spacing: -0.02em; }
    h3 { margin: 0; font-size: 16px; letter-spacing: -0.01em; }
    p { margin: 0; color: var(--muted); line-height: 1.6; }
    label { font-size: 14px; color: var(--text); }
    button {
      background: linear-gradient(135deg, var(--accent), var(--accent-strong));
      color: #fff;
      border: 0;
      border-radius: 12px;
      padding: 12px 18px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      box-shadow: 0 10px 24px rgba(37, 99, 235, 0.2);
    }
    select {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px 12px;
      background: #fff;
      color: var(--text);
      font-size: 14px;
    }
    .section-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 18px;
    }
    .section-title {
      display: grid;
      gap: 8px;
    }
    .section-kicker {
      color: var(--accent);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .hint {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.5;
    }
    .control-layout {
      display: grid;
      grid-template-columns: 1.2fr 1fr 0.9fr;
      gap: 14px;
      margin-top: 18px;
    }
    .control-group {
      background: var(--panel-soft);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 16px;
      display: grid;
      gap: 12px;
      align-content: start;
    }
    .control-group-title {
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .control-group-copy {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.5;
    }
    .source-options,
    .time-options,
    .control-stack,
    .summary-meta-grid,
    .article-stack {
      display: grid;
      gap: 10px;
    }
    .source-option,
    .time-option {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      padding: 11px 12px;
      border-radius: 12px;
      background: #fff;
      border: 1px solid var(--border);
    }
    .source-option input,
    .time-option input {
      margin-top: 2px;
      accent-color: var(--accent);
    }
    .source-option-text,
    .time-option-text {
      display: grid;
      gap: 4px;
    }
    .source-option-title,
    .time-option-title {
      font-weight: 600;
      color: var(--text);
    }
    .source-option-note,
    .time-option-note,
    .field-note {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.45;
    }
    .field-block {
      display: grid;
      gap: 8px;
    }
    .field-label {
      font-size: 13px;
      font-weight: 600;
      color: var(--text);
    }
    .action-note {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
    }
    .error {
      color: #a61b35;
      margin-top: 14px;
      padding: 12px 14px;
      background: var(--danger-soft);
      border: 1px solid var(--danger-border);
      border-radius: 12px;
      font-size: 13px;
    }
    .summary-grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 14px;
      margin-top: 18px;
    }
    .stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }
    .stat {
      background: var(--panel-soft);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 16px;
    }
    .stat .label {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .stat .value {
      font-size: 30px;
      font-weight: 700;
      margin-top: 10px;
      color: var(--text);
    }
    .stat .foot {
      margin-top: 8px;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.4;
    }
    .summary-meta-card {
      background: var(--panel-soft);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 16px;
      display: grid;
      gap: 12px;
    }
    .summary-meta-item {
      display: grid;
      gap: 5px;
    }
    .summary-meta-label {
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .summary-meta-value {
      font-size: 14px;
      color: var(--text);
      line-height: 1.5;
    }
    .summary-link-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .summary-link-row a {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 9px 12px;
      border-radius: 999px;
      background: var(--accent-soft);
      color: var(--accent-strong);
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
    }
    .empty {
      color: #7b879a;
      font-size: 14px;
      line-height: 1.6;
      padding: 18px;
      border-radius: 14px;
      border: 1px dashed var(--border-strong);
      background: var(--panel-soft);
    }
    .stage-compare-shell {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 16px;
      margin-top: 18px;
      align-items: start;
    }
    .stage-status-rail {
      display: grid;
      gap: 10px;
    }
    .stage-status-item,
    .stage-status-button {
      width: 100%;
      text-align: left;
      display: grid;
      gap: 4px;
      padding: 12px 14px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: var(--panel-soft);
      color: var(--text);
      box-shadow: none;
    }
    .stage-status-item {
      cursor: default;
    }
    .stage-status-button {
      cursor: pointer;
    }
    .stage-status-button.is-active {
      background: var(--accent-soft);
      border-color: rgba(37, 99, 235, 0.38);
    }
    .stage-status-name {
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
    }
    .stage-status-meta {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.45;
    }
    .stage-compare-track {
      display: grid;
      gap: 14px;
    }
    .stage-compare-pair {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }
    .stage-compare-panel {
      background: var(--panel-soft);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px;
      display: grid;
      gap: 12px;
    }
    .stage-panel-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
    }
    .stage-panel-count {
      color: var(--muted);
      font-size: 12px;
      font-weight: 600;
    }
    .article-item {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 11px 12px;
      display: grid;
      gap: 8px;
      font-size: 12px;
    }
    .article-item.is-removed {
      background: #fff7f8;
      border-style: dashed;
      border-color: #e0b8c1;
    }
    .article-item a {
      color: var(--text);
      text-decoration: none;
      font-weight: 700;
      font-size: 13px;
      line-height: 1.45;
    }
    .article-meta {
      color: var(--muted);
      font-size: 11px;
      line-height: 1.45;
    }
    .article-summary-toggle {
      border-top: 1px dashed var(--border);
      padding-top: 8px;
    }
    .article-summary-toggle summary {
      cursor: pointer;
      color: var(--accent);
      font-size: 12px;
      font-weight: 600;
      list-style: none;
    }
    .article-summary-toggle summary::-webkit-details-marker { display: none; }
    .article-summary-body {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.55;
      margin-top: 8px;
    }
    .tag-list {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }
    .tag {
      background: var(--accent-soft);
      color: var(--accent-strong);
      border-radius: 999px;
      font-size: 11px;
      font-weight: 600;
      padding: 4px 8px;
    }
    @media (max-width: 1024px) {
      .control-layout,
      .summary-grid,
      .stage-compare-shell,
      .stage-compare-pair {
        grid-template-columns: 1fr;
      }
    }
    @media (max-width: 720px) {
      .stats { grid-template-columns: 1fr; }
      .panel { padding: 18px; }
    }
  </style>
</head>
<body>
  <div class="page">
    {% include "_dashboard_generation_options.html.j2" %}
    {% include "_dashboard_summary.html.j2" %}
    {% include "_dashboard_stage_details.html.j2" %}
  </div>
</body>
</html>
