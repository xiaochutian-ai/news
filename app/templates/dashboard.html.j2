<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <title>民生晨报 Dashboard</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, sans-serif; color: #222; margin: 0; background: #f5f7fb; }
    .page { max-width: 1180px; margin: 0 auto; padding: 32px 20px 48px; }
    .panel { background: #fff; border-radius: 12px; padding: 20px; box-shadow: 0 4px 20px rgba(15, 23, 42, 0.06); margin-bottom: 20px; }
    h1 { margin: 0 0 12px; font-size: 28px; }
    h2 { margin: 0 0 12px; font-size: 20px; }
    h3 { margin: 0 0 12px; font-size: 18px; }
    p { margin: 0; color: #5b6473; }
    .source-list { display: flex; gap: 16px; flex-wrap: wrap; margin: 16px 0 20px; }
    label { display: inline-flex; align-items: center; gap: 8px; font-size: 15px; }
    button { background: #2563eb; color: #fff; border: 0; border-radius: 8px; padding: 10px 18px; font-size: 15px; cursor: pointer; }
    .error { color: #b42318; margin-top: 12px; }
    .stats { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; margin-top: 16px; }
    .stat { background: #f8fafc; border-radius: 10px; padding: 14px; }
    .stat .label { color: #667085; font-size: 13px; }
    .stat .value { font-size: 24px; font-weight: 600; margin-top: 4px; }
    .meta { margin-top: 12px; color: #667085; font-size: 14px; }
    .files a { color: #2563eb; text-decoration: none; }
    .stage-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; margin-top: 20px; }
    .stage-card { background: #f8fafc; border-radius: 10px; padding: 16px; }
    .stage-count { color: #667085; font-size: 13px; margin-bottom: 14px; }
    .article-list { display: flex; flex-direction: column; gap: 12px; }
    .article-item { background: #fff; border: 1px solid #e4e7ec; border-radius: 10px; padding: 12px; }
    .article-item a { color: #175cd3; text-decoration: none; font-weight: 600; }
    .article-meta { color: #667085; font-size: 13px; margin-top: 8px; }
    .article-summary { color: #344054; font-size: 14px; line-height: 1.5; margin-top: 8px; }
    .empty { color: #98a2b3; font-size: 14px; }
    .tag-list { margin-top: 8px; display: flex; gap: 8px; flex-wrap: wrap; }
    .tag { background: #eff4ff; color: #175cd3; border-radius: 999px; font-size: 12px; padding: 2px 8px; }
    @media (max-width: 900px) { .stats, .stage-grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
  <div class="page">
    {% include "_dashboard_generation_options.html.j2" %}
    {% include "_dashboard_summary.html.j2" %}
    {% include "_dashboard_stage_details.html.j2" %}
  </div>
</body>
</html>
