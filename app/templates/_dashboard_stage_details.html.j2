<div class="panel">
  <div class="section-head">
    <div class="section-title">
      <div class="section-kicker">Stage Compare</div>
      <h2>生成详情</h2>
    </div>
    <div class="hint">默认对比过滤后与去重后。切换阶段时，始终展示前一阶段和当前阶段的并排对照。</div>
  </div>
  {% if result %}
  {% set stage_pairs = [
    {
      "key": "filtered_articles",
      "button_label": "过滤后明细",
      "button_meta": "查看原始候选与过滤后",
      "previous_key": "raw_articles",
      "previous_label": "原始候选明细",
      "previous_hint": "过滤前候选",
      "current_key": "filtered_articles",
      "current_label": "过滤后明细",
      "current_hint": "默认展示保留结果",
    },
    {
      "key": "deduped_articles",
      "button_label": "去重后明细",
      "button_meta": "默认对比阶段",
      "previous_key": "filtered_articles",
      "previous_label": "过滤后明细",
      "previous_hint": "对比去重前结果",
      "current_key": "deduped_articles",
      "current_label": "去重后明细",
      "current_hint": "状态优先高亮",
    },
    {
      "key": "chosen_articles",
      "button_label": "最终入选明细",
      "button_meta": "查看最终入选结果",
      "previous_key": "deduped_articles",
      "previous_label": "去重后明细",
      "previous_hint": "入选前候选",
      "current_key": "chosen_articles",
      "current_label": "最终入选明细",
      "current_hint": "落入晨报草稿",
    },
  ] %}
  <div class="stage-compare-shell" data-default-stage="deduped_articles">
    <div class="stage-status-rail">
      <div class="stage-status-item">
        <span class="stage-status-name">原始候选明细</span>
        <span class="stage-status-meta">数量：{{ result.stages["raw_articles"] | length }} | 作为阶段对照起点</span>
      </div>
      {% for pair in stage_pairs %}
      <button
        type="button"
        class="stage-status-button{% if pair.key == 'deduped_articles' %} is-active{% endif %}"
        data-stage="{{ pair.key }}"
        onclick="switchStageCompare(this.closest('.stage-compare-shell'), '{{ pair.key }}')"
      >
        <span class="stage-status-name">{{ pair.button_label }}</span>
        <span class="stage-status-meta">数量：{{ result.stages[pair.current_key] | length }} | {{ pair.button_meta }}</span>
      </button>
      {% endfor %}
    </div>
    <div class="stage-compare-track">
      {% for pair in stage_pairs %}
      {% set previous_items = result.stages[pair.previous_key] %}
      {% set current_items = result.stages[pair.current_key] %}
      <div class="stage-compare-pair" data-stage-pair="{{ pair.key }}" {% if pair.key != "deduped_articles" %}hidden{% endif %}>
        <section class="stage-compare-panel" data-role="previous">
          <div class="stage-panel-head">
            <div>
              <h3>{{ pair.previous_label }}</h3>
              <div class="stage-panel-count">{{ pair.previous_hint }}</div>
            </div>
            <div class="stage-panel-count">数量：{{ previous_items | length }}</div>
          </div>
          {% if previous_items %}
          <div class="article-stack">
            {% for article in previous_items %}
            <article class="article-item">
              <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a>
              <div class="article-meta">
                来源：{{ article.source }}
                {% if article.published_at %} | 时间：{{ article.published_at }}{% endif %}
                {% if article.score is not none %} | 分数：{{ "%.2f"|format(article.score) }}{% endif %}
              </div>
              {% if article.tags %}
              <div class="tag-list">
                {% for tag in article.tags %}
                <span class="tag">{{ tag }}</span>
                {% endfor %}
              </div>
              {% endif %}
              {% if article.summary %}
              <details class="article-summary-toggle">
                <summary>展开摘要</summary>
                <div class="article-summary-body">{{ article.summary }}</div>
              </details>
              {% endif %}
            </article>
            {% endfor %}
          </div>
          {% else %}
          <div class="empty">当前对照的前一阶段暂无数据。</div>
          {% endif %}
        </section>
        <section class="stage-compare-panel" data-role="current">
          <div class="stage-panel-head">
            <div>
              <h3>{{ pair.current_label }}</h3>
              <div class="stage-panel-count">{{ pair.current_hint }}</div>
            </div>
            <div class="stage-panel-count">数量：{{ current_items | length }}</div>
          </div>
          {% if current_items %}
          <div class="article-stack">
            {% for article in current_items %}
            <article class="article-item{% if pair.key != 'filtered_articles' and loop.index > (current_items | length) %} is-removed{% endif %}">
              <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a>
              <div class="article-meta">
                来源：{{ article.source }}
                {% if article.published_at %} | 时间：{{ article.published_at }}{% endif %}
                {% if article.score is not none %} | 分数：{{ "%.2f"|format(article.score) }}{% endif %}
              </div>
              <div class="article-meta">
                {% if pair.key == "deduped_articles" %}
                保留原因：同主题候选中重复度更低，进入去重后集合
                {% elif pair.key == "chosen_articles" %}
                保留原因：进入最终晨报草稿
                {% else %}
                保留原因：通过主题相关性过滤
                {% endif %}
              </div>
              {% if article.tags %}
              <div class="tag-list">
                {% for tag in article.tags %}
                <span class="tag">{{ tag }}</span>
                {% endfor %}
              </div>
              {% endif %}
              {% if article.summary %}
              <details class="article-summary-toggle">
                <summary>展开摘要</summary>
                <div class="article-summary-body">{{ article.summary }}</div>
              </details>
              {% endif %}
            </article>
            {% endfor %}
            {% if pair.key == "deduped_articles" and previous_items | length > current_items | length %}
            <article class="article-item is-removed">
              <div><strong>重复候选已折叠</strong></div>
              <div class="article-meta">已从过滤后集合移除 {{ (previous_items | length) - (current_items | length) }} 条高度重复内容。</div>
            </article>
            {% endif %}
          </div>
          {% else %}
          <div class="empty">当前阶段暂无数据。</div>
          {% endif %}
        </section>
      </div>
      {% endfor %}
    </div>
  </div>
  {% else %}
  <div class="empty">还没有执行记录。执行一次晨报生成后，这里会默认展示过滤后与去重后的阶段对照。</div>
  {% endif %}
</div>
<script>
function switchStageCompare(container, stageKey) {
  const buttons = container.querySelectorAll("[data-stage]");
  const panels = container.querySelectorAll("[data-stage-pair]");
  buttons.forEach((button) => {
    button.classList.toggle("is-active", button.dataset.stage === stageKey);
  });
  panels.forEach((panel) => {
    panel.hidden = panel.dataset.stagePair !== stageKey;
  });
}

document.querySelectorAll(".stage-compare-shell").forEach((container) => {
  const defaultStage = container.dataset.defaultStage || "deduped_articles";
  switchStageCompare(container, defaultStage);
});
</script>
