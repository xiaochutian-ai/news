<section class="panel details-panel">
  <div class="section-head">
    <div>
      <div class="section-kicker">Stage Intelligence</div>
      <h2>生成详情</h2>
    </div>
    <div class="hint">上半部分负责选中阶段，下半部分固定展示该阶段前后的聚合对比，并单独补充删除条目和排序变化。</div>
  </div>
  {% if result %}
  <div class="stage-compare-shell" data-default-stage="{{ default_stage_pair_key }}">
    <section class="stage-selector-panel">
      <div class="stage-selector-head">
        <h3>阶段选择</h3>
        <div class="stage-panel-count">先选阶段，再看该阶段的前后差异和排序变化</div>
      </div>
      <div class="stage-status-rail">
        {% for pair in stage_compare_options %}
        <button
          type="button"
          class="stage-status-button{% if pair.key == default_stage_pair_key %} is-active{% endif %}"
          data-stage="{{ pair.key }}"
          onclick="switchStageCompare(this.closest('.stage-compare-shell'), '{{ pair.key }}')"
        >
          <span class="stage-status-name">{{ pair.button_label }}</span>
          <span class="stage-status-meta">剩余 {{ pair.after_count }} · 删除 {{ pair.removed_count }}</span>
        </button>
        {% endfor %}
      </div>
    </section>
    <div class="stage-compare-track">
      {% if active_stage_compare %}
      <div class="stage-compare-view" data-stage-view="{{ active_stage_compare.key }}">
        <section class="stage-summary-panel">
          <div class="stage-workspace-head">
            <div>
              <div class="stage-overview-label">阶段摘要</div>
              <div class="stage-summary-title">{{ active_stage_compare.button_label }}</div>
            </div>
            <div class="stage-workspace-copy">{{ active_stage_compare.button_meta }}</div>
          </div>
          <div class="stage-summary-strip">
            <article class="stage-summary-chip">
              <div class="stage-overview-label">前后数量</div>
              <div class="stage-summary-metric">{{ active_stage_compare.previous_count }} -> {{ active_stage_compare.after_count }}</div>
            </article>
            <article class="stage-summary-chip">
              <div class="stage-overview-label">删除条目</div>
              <div class="stage-summary-metric">{{ active_stage_compare.removed_count }}</div>
            </article>
            <article class="stage-summary-chip">
              <div class="stage-overview-label">排序变化</div>
              <div class="stage-summary-metric">{{ active_stage_compare.rank_change_count }}</div>
            </article>
            <article class="stage-summary-chip">
              <div class="stage-overview-label">阅读方式</div>
              <div class="stage-summary-copy">先看主视区，再按需展开次级差异</div>
            </article>
          </div>
        </section>
        <section class="stage-primary-workspace">
          <div class="stage-workspace-head">
            <div class="stage-overview-label">主视区</div>
            <div class="stage-workspace-copy">左边看进入本阶段前的聚合结果，右边看经过当前阶段后保留下来的结果</div>
          </div>
        <div class="stage-compare-pair is-asymmetric">
          <section class="stage-compare-panel is-before" data-role="before">
            <div class="stage-panel-head">
              <div>
                <h3>阶段前聚合结果</h3>
                <div class="stage-panel-count">{{ active_stage_compare.previous_label }} · {{ active_stage_compare.previous_hint }}</div>
              </div>
              <div class="stage-panel-count">总条数 {{ active_stage_compare.previous_count }}</div>
            </div>
            {% if active_stage_compare.before_breakdown %}
            <div class="source-breakdown-row is-before-breakdown">
              {% for item in active_stage_compare.before_breakdown %}
              <span class="source-breakdown-chip">{{ item.source }} {{ item.count }}</span>
              {% endfor %}
            </div>
            {% endif %}
            {% if active_stage_compare.before_items %}
            <div class="article-stack is-dense">
              {% for article in active_stage_compare.before_items %}
              <article class="article-item compact-item is-before-item">
                <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a>
                <div class="article-meta">
                  来源：{{ article.source }}
                  {% if article.published_at %} | 时间：{{ article.published_at }}{% endif %}
                  {% if article.score is not none %} | 分数：{{ "%.2f"|format(article.score) }}{% endif %}
                </div>
                <div class="article-meta">阶段前位次：{{ loop.index }}</div>
                {% if article.tags %}
                <div class="tag-list">
                  {% for tag in article.tags %}
                  <span class="tag">{{ tag }}</span>
                  {% endfor %}
                </div>
                {% endif %}
                {% if article.summary %}
                <details class="article-summary-toggle">
                  <summary>展开摘要</summary>
                  <div class="article-summary-body">{{ article.summary }}</div>
                </details>
                {% endif %}
              </article>
              {% endfor %}
            </div>
            {% else %}
            <div class="empty">当前阶段之前暂无聚合数据。</div>
            {% endif %}
          </section>
          <section class="stage-compare-panel is-after" data-role="after">
            <div class="stage-panel-head">
              <div>
                <h3>阶段后保留结果</h3>
                <div class="stage-panel-count">{{ active_stage_compare.current_label }} · {{ active_stage_compare.current_hint }}</div>
              </div>
              <div class="stage-panel-count">保留条数 {{ active_stage_compare.after_count }}</div>
            </div>
            {% if active_stage_compare.after_breakdown %}
            <div class="source-breakdown-row is-after-breakdown">
              {% for item in active_stage_compare.after_breakdown %}
              <span class="source-breakdown-chip">{{ item.source }} {{ item.count }}</span>
              {% endfor %}
            </div>
            {% endif %}
            {% if active_stage_compare.after_items %}
            <div class="article-stack is-focus">
              {% for article in active_stage_compare.after_items %}
              <article class="article-item compact-item is-after-item">
                <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a>
                <div class="article-meta">
                  来源：{{ article.source }}
                  {% if article.published_at %} | 时间：{{ article.published_at }}{% endif %}
                  {% if article.score is not none %} | 分数：{{ "%.2f"|format(article.score) }}{% endif %}
                </div>
                <div class="article-meta">保留原因：{{ active_stage_compare.status_copy }}</div>
                {% if article.before_rank is not none and article.after_rank is not none %}
                <div class="article-meta">排序变化：{{ article.before_rank }} -> {{ article.after_rank }}</div>
                {% endif %}
                {% if article.tags %}
                <div class="tag-list">
                  {% for tag in article.tags %}
                  <span class="tag">{{ tag }}</span>
                  {% endfor %}
                </div>
                {% endif %}
                {% if article.summary %}
                <details class="article-summary-toggle">
                  <summary>展开摘要</summary>
                  <div class="article-summary-body">{{ article.summary }}</div>
                </details>
                {% endif %}
              </article>
              {% endfor %}
            </div>
            {% else %}
            <div class="empty">当前阶段之后没有保留下来的数据。</div>
            {% endif %}
          </section>
        </div>
        </section>
        <section class="stage-secondary-panel">
          <div class="stage-workspace-head">
            <div class="stage-overview-label">次级差异</div>
            <div class="stage-workspace-copy">这里放删除条目和排序变化，默认折叠，避免主画面过载</div>
          </div>
          <div class="stage-secondary-row">
            <details class="stage-secondary-details">
              <summary>
                <span>删除条目（可展开）</span>
                <span class="stage-panel-count">共 {{ active_stage_compare.removed_count }} 条</span>
              </summary>
              <div class="stage-diff-card">
                <div class="stage-panel-head">
                  <div>
                    <h3>删除条目</h3>
                    <div class="stage-panel-count">本阶段被删掉的文章，以及统一的阶段原因</div>
                  </div>
                  <div class="stage-panel-count">共 {{ active_stage_compare.removed_count }} 条</div>
                </div>
                {% if active_stage_compare.removed_items %}
                <div class="article-stack">
                  {% for article in active_stage_compare.removed_items %}
                  <article class="article-item compact-item is-removed">
                    <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a>
                    <div class="article-meta">
                      来源：{{ article.source }}
                      {% if article.published_at %} | 时间：{{ article.published_at }}{% endif %}
                      {% if article.score is not none %} | 分数：{{ "%.2f"|format(article.score) }}{% endif %}
                    </div>
                    <div class="article-meta">删除原因：{{ active_stage_compare.removed_reason }}</div>
                    {% if article.tags %}
                    <div class="tag-list">
                      {% for tag in article.tags %}
                      <span class="tag">{{ tag }}</span>
                      {% endfor %}
                    </div>
                    {% endif %}
                    {% if article.summary %}
                    <details class="article-summary-toggle">
                      <summary>展开摘要</summary>
                      <div class="article-summary-body">{{ article.summary }}</div>
                    </details>
                    {% endif %}
                  </article>
                  {% endfor %}
                </div>
                {% else %}
                <div class="empty">当前阶段没有删掉任何文章。</div>
                {% endif %}
              </div>
            </details>
            <details class="stage-secondary-details">
              <summary>
                <span>排序变化（可展开）</span>
                <span class="stage-panel-count">变化 {{ active_stage_compare.rank_change_count }} 条</span>
              </summary>
              <div class="stage-diff-card">
                <div class="stage-panel-head">
                  <div>
                    <h3>排序变化</h3>
                    <div class="stage-panel-count">保留下来的文章在本阶段前后位次如何变化</div>
                  </div>
                  <div class="stage-panel-count">变化 {{ active_stage_compare.rank_change_count }} 条</div>
                </div>
                {% if active_stage_compare.rank_changes %}
                <div class="rank-change-list">
                  {% for item in active_stage_compare.rank_changes %}
                  <article class="rank-change-item{% if item.rank_delta == 0 %} is-neutral{% endif %}">
                    <div class="rank-change-title">{{ item.title }}</div>
                    <div class="article-meta">来源：{{ item.source }}</div>
                    <div class="rank-change-meta">位次：{{ item.before_rank }} -> {{ item.after_rank }} | {{ item.direction }}</div>
                  </article>
                  {% endfor %}
                </div>
                {% else %}
                <div class="empty">当前阶段没有可比较的排序变化。</div>
                {% endif %}
              </div>
            </details>
          </div>
        </section>
      </div>
      {% endif %}
    </div>
    <script type="application/json" class="stage-compare-data">{{ stage_compare_json | safe }}</script>
  </div>
  {% else %}
  <div class="empty">这里会默认展示过滤后与去重后的阶段对照，并支持切换到最终入选视图。</div>
  {% endif %}
</section>
<script>
function escapeStageHtml(value) {
  return String(value ?? "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");
}

function renderSourceBreakdown(items) {
  if (!items.length) return "";
  return `<div class="source-breakdown-row">${items.map((item) => `<span class="source-breakdown-chip">${escapeStageHtml(item.source)} ${item.count}</span>`).join("")}</div>`;
}

function renderStageArticle(article, extraMeta = [], itemClass = "") {
  const tags = (article.tags || [])
    .map((tag) => `<span class="tag">${escapeStageHtml(tag)}</span>`)
    .join("");
  const summary = article.summary
    ? `<details class="article-summary-toggle"><summary>展开摘要</summary><div class="article-summary-body">${escapeStageHtml(article.summary)}</div></details>`
    : "";
  const metaParts = [`来源：${escapeStageHtml(article.source || "")}`];
  if (article.published_at) metaParts.push(`时间：${escapeStageHtml(article.published_at)}`);
  if (article.score !== null && article.score !== undefined) metaParts.push(`分数：${Number(article.score).toFixed(2)}`);
  const extra = extraMeta
    .filter(Boolean)
    .map((item) => `<div class="article-meta">${escapeStageHtml(item)}</div>`)
    .join("");
  return `
    <article class="article-item compact-item${itemClass ? ` ${itemClass}` : ""}">
      <a href="${escapeStageHtml(article.url || "#")}" target="_blank" rel="noopener noreferrer">${escapeStageHtml(article.title || "")}</a>
      <div class="article-meta">${metaParts.join(" | ")}</div>
      ${extra}
      ${tags ? `<div class="tag-list">${tags}</div>` : ""}
      ${summary}
    </article>
  `;
}

function renderArticleStack(items, emptyCopy, metaBuilder, stackClass = "", itemClass = "") {
  return `
    ${items.length
      ? `<div class="article-stack${stackClass ? ` ${stackClass}` : ""}">${items.map((article, index) => renderStageArticle(article, metaBuilder(article, index), itemClass)).join("")}</div>`
      : `<div class="empty">${escapeStageHtml(emptyCopy)}</div>`}
  `;
}

function renderRankChangeList(items) {
  if (!items.length) {
    return `<div class="empty">当前阶段没有可比较的排序变化。</div>`;
  }
  return `
    <div class="rank-change-list">
      ${items.map((item) => `
        <article class="rank-change-item${item.rank_delta === 0 ? " is-neutral" : ""}">
          <div class="rank-change-title">${escapeStageHtml(item.title || "")}</div>
          <div class="article-meta">来源：${escapeStageHtml(item.source || "")}</div>
          <div class="rank-change-meta">位次：${item.before_rank} -> ${item.after_rank} | ${escapeStageHtml(item.direction || "")}</div>
        </article>
      `).join("")}
    </div>
  `;
}

function switchStageCompare(container, stageKey) {
  const buttons = container.querySelectorAll("[data-stage]");
  const dataEl = container.querySelector(".stage-compare-data");
  const viewEl = container.querySelector("[data-stage-view]");
  if (!dataEl || !viewEl) return;
  const stagePairs = JSON.parse(dataEl.textContent || "[]");
  const pair = stagePairs.find((item) => item.key === stageKey);
  if (!pair) return;
  buttons.forEach((button) => {
    button.classList.toggle("is-active", button.dataset.stage === stageKey);
  });
  viewEl.dataset.stageView = stageKey;
  viewEl.innerHTML = `
    <section class="stage-summary-panel">
      <div class="stage-workspace-head">
        <div>
          <div class="stage-overview-label">阶段摘要</div>
          <div class="stage-summary-title">${escapeStageHtml(pair.button_label)}</div>
        </div>
        <div class="stage-workspace-copy">${escapeStageHtml(pair.button_meta)}</div>
      </div>
      <div class="stage-summary-strip">
        <article class="stage-summary-chip">
          <div class="stage-overview-label">前后数量</div>
          <div class="stage-summary-metric">${pair.previous_count} -> ${pair.after_count}</div>
        </article>
        <article class="stage-summary-chip">
          <div class="stage-overview-label">删除条目</div>
          <div class="stage-summary-metric">${pair.removed_count}</div>
        </article>
        <article class="stage-summary-chip">
          <div class="stage-overview-label">排序变化</div>
          <div class="stage-summary-metric">${pair.rank_change_count}</div>
        </article>
        <article class="stage-summary-chip">
          <div class="stage-overview-label">阅读方式</div>
          <div class="stage-summary-copy">先看主视区，再按需展开次级差异</div>
        </article>
      </div>
    </section>
    <section class="stage-primary-workspace">
      <div class="stage-workspace-head">
        <div class="stage-overview-label">主视区</div>
        <div class="stage-workspace-copy">左边看进入本阶段前的聚合结果，右边看经过当前阶段后保留下来的结果</div>
      </div>
      <div class="stage-compare-pair is-asymmetric">
        <section class="stage-compare-panel is-before" data-role="before">
          <div class="stage-panel-head">
            <div>
              <h3>阶段前聚合结果</h3>
              <div class="stage-panel-count">${escapeStageHtml(pair.previous_label)} · ${escapeStageHtml(pair.previous_hint)}</div>
            </div>
            <div class="stage-panel-count">总条数 ${pair.previous_count}</div>
          </div>
          ${pair.before_breakdown?.length ? `<div class="source-breakdown-row is-before-breakdown">${(pair.before_breakdown || []).map((item) => `<span class="source-breakdown-chip">${escapeStageHtml(item.source)} ${item.count}</span>`).join("")}</div>` : ""}
          ${renderArticleStack(pair.before_items || [], "当前阶段之前暂无聚合数据。", (_, index) => [`阶段前位次：${index + 1}`], "is-dense", "is-before-item")}
        </section>
        <section class="stage-compare-panel is-after" data-role="after">
          <div class="stage-panel-head">
            <div>
              <h3>阶段后保留结果</h3>
              <div class="stage-panel-count">${escapeStageHtml(pair.current_label)} · ${escapeStageHtml(pair.current_hint)}</div>
            </div>
            <div class="stage-panel-count">保留条数 ${pair.after_count}</div>
          </div>
          ${pair.after_breakdown?.length ? `<div class="source-breakdown-row is-after-breakdown">${(pair.after_breakdown || []).map((item) => `<span class="source-breakdown-chip">${escapeStageHtml(item.source)} ${item.count}</span>`).join("")}</div>` : ""}
          ${renderArticleStack(pair.after_items || [], "当前阶段之后没有保留下来的数据。", (article) => {
            const meta = [`保留原因：${pair.status_copy}`];
            if (article.before_rank !== null && article.before_rank !== undefined && article.after_rank !== null && article.after_rank !== undefined) {
              meta.push(`排序变化：${article.before_rank} -> ${article.after_rank}`);
            }
            return meta;
          }, "is-focus", "is-after-item")}
        </section>
      </div>
    </section>
    <section class="stage-secondary-panel">
      <div class="stage-workspace-head">
        <div class="stage-overview-label">次级差异</div>
        <div class="stage-workspace-copy">这里放删除条目和排序变化，默认折叠，避免主画面过载</div>
      </div>
      <div class="stage-secondary-row">
        <details class="stage-secondary-details">
          <summary>
            <span>删除条目（可展开）</span>
            <span class="stage-panel-count">共 ${pair.removed_count} 条</span>
          </summary>
          <div class="stage-diff-card">
            <div class="stage-panel-head">
              <div>
                <h3>删除条目</h3>
                <div class="stage-panel-count">本阶段被删掉的文章，以及统一的阶段原因</div>
              </div>
              <div class="stage-panel-count">共 ${pair.removed_count} 条</div>
            </div>
            ${renderArticleStack(pair.removed_items || [], "当前阶段没有删掉任何文章。", () => [`删除原因：${pair.removed_reason}`])}
          </div>
        </details>
        <details class="stage-secondary-details">
          <summary>
            <span>排序变化（可展开）</span>
            <span class="stage-panel-count">变化 ${pair.rank_change_count} 条</span>
          </summary>
          <div class="stage-diff-card">
            <div class="stage-panel-head">
              <div>
                <h3>排序变化</h3>
                <div class="stage-panel-count">保留下来的文章在本阶段前后位次如何变化</div>
              </div>
              <div class="stage-panel-count">变化 ${pair.rank_change_count} 条</div>
            </div>
            ${renderRankChangeList(pair.rank_changes || [])}
          </div>
        </details>
      </div>
    </section>
  `;
}

document.querySelectorAll(".stage-compare-shell").forEach((container) => {
  const defaultStage = container.dataset.defaultStage || "filtered_articles";
  switchStageCompare(container, defaultStage);
});
</script>
