<section class="panel details-panel">
  <div class="section-head">
    <div>
      <div class="section-kicker">Stage Intelligence</div>
      <h2>生成详情</h2>
    </div>
    <div class="hint">一次只展示当前选中的一组阶段对照。右栏只保留左栏条目中进入下一阶段的结果。</div>
  </div>
  {% if result %}
  <div class="stage-compare-shell" data-default-stage="{{ default_stage_pair_key }}">
    <div class="stage-status-rail">
      {% for pair in stage_compare_options %}
      <button
        type="button"
        class="stage-status-button{% if pair.key == default_stage_pair_key %} is-active{% endif %}"
        data-stage="{{ pair.key }}"
        onclick="switchStageCompare(this.closest('.stage-compare-shell'), '{{ pair.key }}')"
      >
        <span class="stage-status-name">{{ pair.button_label }}</span>
        <span class="stage-status-meta">数量 {{ pair.passed_count }} | {{ pair.button_meta }}</span>
      </button>
      {% endfor %}
    </div>
    <div class="stage-compare-track">
      {% if active_stage_compare %}
      <div class="stage-compare-pair" data-stage-pair="{{ active_stage_compare.key }}">
        <section class="stage-compare-panel" data-role="previous">
          <div class="stage-panel-head">
            <div>
              <h3>{{ active_stage_compare.previous_label }}</h3>
              <div class="stage-panel-count">{{ active_stage_compare.previous_hint }}</div>
            </div>
            <div class="stage-panel-count">总条数 {{ active_stage_compare.previous_count }}</div>
          </div>
          {% if active_stage_compare.previous_items %}
          <div class="article-stack">
            {% for article in active_stage_compare.previous_items %}
            <article class="article-item compact-item">
              <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a>
              <div class="article-meta">
                来源：{{ article.source }}
                {% if article.published_at %} | 时间：{{ article.published_at }}{% endif %}
                {% if article.score is not none %} | 分数：{{ "%.2f"|format(article.score) }}{% endif %}
              </div>
              {% if article.tags %}
              <div class="tag-list">
                {% for tag in article.tags %}
                <span class="tag">{{ tag }}</span>
                {% endfor %}
              </div>
              {% endif %}
              {% if article.summary %}
              <details class="article-summary-toggle">
                <summary>展开摘要</summary>
                <div class="article-summary-body">{{ article.summary }}</div>
              </details>
              {% endif %}
            </article>
            {% endfor %}
          </div>
          {% else %}
          <div class="empty">当前阶段的前一阶段暂无数据。</div>
          {% endif %}
        </section>
        <section class="stage-compare-panel" data-role="current">
          <div class="stage-panel-head">
            <div>
              <h3>{{ active_stage_compare.current_label }}</h3>
              <div class="stage-panel-count">{{ active_stage_compare.current_hint }}</div>
            </div>
            <div class="stage-panel-count">当前阶段通过数 {{ active_stage_compare.passed_count }}</div>
            <div class="stage-panel-count">当前阶段淘汰数 {{ active_stage_compare.removed_count }}</div>
          </div>
          {% if active_stage_compare.passed_items %}
          <div class="article-stack">
            {% for article in active_stage_compare.passed_items %}
            <article class="article-item compact-item">
              <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a>
              <div class="article-meta">
                来源：{{ article.source }}
                {% if article.published_at %} | 时间：{{ article.published_at }}{% endif %}
                {% if article.score is not none %} | 分数：{{ "%.2f"|format(article.score) }}{% endif %}
              </div>
              <div class="article-meta">
                保留原因：{{ active_stage_compare.status_copy }}
              </div>
              {% if article.tags %}
              <div class="tag-list">
                {% for tag in article.tags %}
                <span class="tag">{{ tag }}</span>
                {% endfor %}
              </div>
              {% endif %}
              {% if article.summary %}
              <details class="article-summary-toggle">
                <summary>展开摘要</summary>
                <div class="article-summary-body">{{ article.summary }}</div>
              </details>
              {% endif %}
            </article>
            {% endfor %}
          </div>
          {% else %}
          <div class="empty">当前组中没有条目进入下一阶段。</div>
          {% endif %}
        </section>
      </div>
      {% endif %}
    </div>
  </div>
  <script type="application/json" class="stage-compare-data">{{ stage_compare_json | safe }}</script>
  {% else %}
  <div class="empty">这里会默认展示过滤后与去重后的阶段对照，并支持切换到最终入选视图。</div>
  {% endif %}
</section>
<script>
function escapeStageHtml(value) {
  return String(value ?? "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#39;");
}

function renderStageArticle(article, statusCopy) {
  const tags = (article.tags || [])
    .map((tag) => `<span class="tag">${escapeStageHtml(tag)}</span>`)
    .join("");
  const summary = article.summary
    ? `<details class="article-summary-toggle"><summary>展开摘要</summary><div class="article-summary-body">${escapeStageHtml(article.summary)}</div></details>`
    : "";
  const metaParts = [`来源：${escapeStageHtml(article.source || "")}`];
  if (article.published_at) metaParts.push(`时间：${escapeStageHtml(article.published_at)}`);
  if (article.score !== null && article.score !== undefined) metaParts.push(`分数：${Number(article.score).toFixed(2)}`);
  const status = statusCopy ? `<div class="article-meta">保留原因：${escapeStageHtml(statusCopy)}</div>` : "";
  return `
    <article class="article-item compact-item">
      <a href="${escapeStageHtml(article.url || "#")}" target="_blank" rel="noopener noreferrer">${escapeStageHtml(article.title || "")}</a>
      <div class="article-meta">${metaParts.join(" | ")}</div>
      ${status}
      ${tags ? `<div class="tag-list">${tags}</div>` : ""}
      ${summary}
    </article>
  `;
}

function switchStageCompare(container, stageKey) {
  const buttons = container.querySelectorAll("[data-stage]");
  const dataEl = container.querySelector(".stage-compare-data");
  const pairEl = container.querySelector("[data-stage-pair]");
  if (!dataEl || !pairEl) return;
  const stagePairs = JSON.parse(dataEl.textContent || "[]");
  const pair = stagePairs.find((item) => item.key === stageKey);
  if (!pair) return;
  buttons.forEach((button) => {
    button.classList.toggle("is-active", button.dataset.stage === stageKey);
  });
  pairEl.dataset.stagePair = stageKey;
  pairEl.innerHTML = `
    <section class="stage-compare-panel" data-role="previous">
      <div class="stage-panel-head">
        <div>
          <h3>${escapeStageHtml(pair.previous_label)}</h3>
          <div class="stage-panel-count">${escapeStageHtml(pair.previous_hint)}</div>
        </div>
        <div class="stage-panel-count">总条数 ${pair.previous_count}</div>
      </div>
      ${pair.previous_items.length
        ? `<div class="article-stack">${pair.previous_items.map((article) => renderStageArticle(article, "")).join("")}</div>`
        : `<div class="empty">当前阶段的前一阶段暂无数据。</div>`}
    </section>
    <section class="stage-compare-panel" data-role="current">
      <div class="stage-panel-head">
        <div>
          <h3>${escapeStageHtml(pair.current_label)}</h3>
          <div class="stage-panel-count">${escapeStageHtml(pair.current_hint)}</div>
        </div>
        <div class="stage-panel-count">当前阶段通过数 ${pair.passed_count}</div>
        <div class="stage-panel-count">当前阶段淘汰数 ${pair.removed_count}</div>
      </div>
      ${pair.passed_items.length
        ? `<div class="article-stack">${pair.passed_items.map((article) => renderStageArticle(article, pair.status_copy)).join("")}</div>`
        : `<div class="empty">当前组中没有条目进入下一阶段。</div>`}
    </section>
  `;
}

document.querySelectorAll(".stage-compare-shell").forEach((container) => {
  const defaultStage = container.dataset.defaultStage || "deduped_articles";
  switchStageCompare(container, defaultStage);
});
</script>
