<section class="panel details-panel">
  <div class="section-head">
    <div>
      <div class="section-kicker">Stage Intelligence</div>
      <h2>生成详情</h2>
    </div>
    <div class="hint">阶段视图保留全链路，来源视图帮助你更快判断各信源的实际贡献。</div>
  </div>
  {% if result %}
  <div class="detail-toolbar">
    <div class="view-chip">阶段总览</div>
    <div class="view-chip">按来源分组</div>
    <div class="hint">文章卡片默认压缩显示，展开后可查看完整列表。</div>
  </div>
  <div class="stage-grid">
    {% for stage in stage_sections %}
    {% set items = result.stages[stage.key] %}
    <div class="stage-card">
      <div class="stage-head">
        <h3>{{ stage.label }}</h3>
        <div class="stage-count">数量 {{ items | length }}</div>
      </div>
      {% if items %}
      {% set grouped = {} %}
      {% for article in items %}
      {% set _ = grouped.update({article.source: grouped.get(article.source, []) + [article]}) %}
      {% endfor %}
      <details class="stage-details" {% if loop.first %}open{% endif %}>
        <summary>
          <span>展开阶段明细</span>
          <span class="summary-meta">按来源分组</span>
        </summary>
        <div class="source-group-grid">
          {% for source_name, source_items in grouped.items() %}
          <div class="source-group-card">
            <div class="source-group-head">
              <strong>{{ source_name }}</strong>
              <span>{{ source_items | length }} 条</span>
            </div>
            <div class="article-list compact-list">
              {% for article in source_items[:3] %}
              <article class="article-item compact-item">
                <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a>
                <div class="article-meta">
                  {% if article.published_at %}{{ article.published_at }}{% endif %}
                  {% if article.score is not none %} | 分数：{{ "%.2f"|format(article.score) }}{% endif %}
                </div>
                <div class="article-summary">{{ article.summary }}</div>
                {% if article.tags %}
                <div class="tag-list">
                  {% for tag in article.tags %}
                  <span class="tag">{{ tag }}</span>
                  {% endfor %}
                </div>
                {% endif %}
              </article>
              {% endfor %}
            </div>
            {% if source_items | length > 3 %}
            <details class="stage-details secondary-details">
              <summary>
                <span>展开剩余 {{ (source_items | length) - 3 }} 条</span>
                <span class="summary-meta">二次展开</span>
              </summary>
              <div class="article-list compact-list">
                {% for article in source_items[3:] %}
                <article class="article-item compact-item">
                  <a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a>
                  <div class="article-meta">
                    {% if article.published_at %}{{ article.published_at }}{% endif %}
                    {% if article.score is not none %} | 分数：{{ "%.2f"|format(article.score) }}{% endif %}
                  </div>
                  <div class="article-summary">{{ article.summary }}</div>
                  {% if article.tags %}
                  <div class="tag-list">
                    {% for tag in article.tags %}
                    <span class="tag">{{ tag }}</span>
                    {% endfor %}
                  </div>
                  {% endif %}
                </article>
                {% endfor %}
              </div>
            </details>
            {% endif %}
          </div>
          {% endfor %}
        </div>
      </details>
      {% else %}
      <div class="empty">当前阶段暂无数据。</div>
      {% endif %}
    </div>
    {% endfor %}
  </div>
  {% else %}
  <div class="empty">这里会显示原始候选、过滤后、去重后和最终入选四个阶段的文章明细。</div>
  {% endif %}
</section>
